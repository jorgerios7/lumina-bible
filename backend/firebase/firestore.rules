rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsResource() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingResource() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, update, delete: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.resource.data.id == request.auth.uid;
    }

    match /studies/{studyId} {
      allow read, update, delete: if ownsResource();
      allow create: if ownsIncomingResource();
    }

    match /studyNodes/{nodeId} {
      allow read, update, delete: if ownsResource();
      allow create: if ownsIncomingResource();
    }

    match /messages/{messageId} {
      allow read, update, delete: if ownsResource();
      allow create: if ownsIncomingResource();
    }

    match /favorites/{favoriteId} {
      allow read, update, delete: if ownsResource();
      allow create: if ownsIncomingResource();
    }

    match /notes/{noteId} {
      allow read, update, delete: if ownsResource();
      allow create: if ownsIncomingResource();
    }

    match /settings/{userId} {
      allow read, update, delete: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
    }
  }
}
